# Copy this file to .env and fill in your PayPal sandbox or live credentials.
# Then run `node server.js` (no need to set env vars manually).

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_SANDBOX_CLIENT_SECRET_HERE

# Optional: set HOST and PORT if you want to run on a different host/port
# HOST=localhost
# PORT=3000
